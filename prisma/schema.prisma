// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector]
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model VastuLog {
  id        Int      @id @default(autoincrement())
  direction String
  query     String
  createdAt DateTime @default(now())
}

model CustomerImage {
  id             Int      @id @default(autoincrement())
  imageData      String   // Storing Base64 or URL
  analysisResult String?
  createdAt      DateTime @default(now())
}

model VastuConfig {
  id             Int      @id @default(autoincrement())
  direction      String   @unique
  recommendation String
  keywords       String
}

model AppSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model ProductEmbedding {
  id          String   @id @default(uuid())
  productId   String   @unique
  embedding   Unsupported("vector(768)") // 768 dimensions for text-embedding-004
  textPayload String   // Stores the concatenated text used to generate the embedding
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AgentSession {
  id               String   @id // Maps to Shopify session ID
  roomType         String?
  colorPalette     String?
  moodVibe         String?
  wallSize         String?
  collectedState   String   @default("INTERVIEWING") // INTERVIEWING, SEARCHING, CURATING
  rawHistoryJson   String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
