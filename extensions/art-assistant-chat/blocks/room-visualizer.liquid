<div class="art-visualizer-container">
  {% if product.featured_image %}
    <button id="visualizer-trigger-{{ block.id }}" class="visualizer-btn" type="button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
      <span>View in Your Room (3D)</span>
    </button>

    <!-- Modal Overlay -->
    <div id="visualizer-modal-{{ block.id }}" class="visualizer-modal hidden">
      <div class="visualizer-header">
        <h2>3D Room Visualizer</h2>
        <button id="visualizer-close-{{ block.id }}" class="close-btn">&times;</button>
      </div>
      
      <div class="visualizer-body">
        
        <div class="visualizer-controls" id="visualizer-controls-{{ block.id }}">
           <label for="visualizer-upload-{{ block.id }}" class="upload-label">
             <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
             Upload Wall Photo
           </label>
           <input type="file" id="visualizer-upload-{{ block.id }}" accept="image/*" hidden>
           <p class="instructions hidden" id="viz-inst-{{ block.id }}">Drag to position. Use sliders to tune 3D angle & size.</p>
        </div>

        <!-- The Interactive Canvas Area -->
        <div class="visualizer-canvas" id="visualizer-canvas-{{ block.id }}">
           <!-- Background Room Image -->
           <img id="room-bg-{{ block.id }}" class="room-bg hidden" src="" />
           
           <!-- Perspective Wrapper for 3D Math -->
           <div class="perspective-wrapper" id="perspective-wrapper-{{ block.id }}">
               <!-- The Product Image (Draggable & Rotatable) -->
               <div id="draggable-art-{{ block.id }}" class="draggable-art hidden">
                 <div class="art-frame">
                   <img src="{{ product.featured_image | image_url: width: 1024 }}" alt="{{ product.title }}">
                   <div class="glass-reflection"></div>
                 </div>
                 <!-- Super realistic drop shadow separate from the element to allow 3D lift -->
                 <div class="art-shadow"></div>
               </div>
           </div>
           
           <div class="empty-state" id="empty-state-{{ block.id }}">
             <div class="empty-icon">📸</div>
             <p>Upload a photo of your room to see this painting on your wall.</p>
           </div>
        </div>

        <!-- 3D Tuning Panel (Hidden initially) -->
        <div class="tuning-panel hidden" id="tuning-panel-{{ block.id }}">
            <div class="slider-group">
                <label>Size <span id="size-val-{{ block.id }}">100%</span></label>
                <input type="range" id="size-slider-{{ block.id }}" min="20" max="250" value="100">
            </div>
            <div class="slider-group">
                <label>Wall Perspective (Tilt) <span id="tilt-val-{{ block.id }}">0°</span></label>
                <input type="range" id="tilt-slider-{{ block.id }}" min="-60" max="60" value="0">
            </div>
        </div>
      </div>
      
      <div class="visualizer-footer hidden" id="viz-footer-{{ block.id }}">
        <button class="viz-btn-outline" id="viz-reupload-{{ block.id }}">Change Photo</button>
        <button class="viz-btn-primary" id="viz-done-{{ block.id }}">Looks Great!</button>
      </div>
    </div>
  {% endif %}
</div>

<style>
  /* Button Styles */
  .visualizer-btn {
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, #111, #333);
    color: #fff;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    margin: 20px 0;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.2);
  }
  .visualizer-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.3);
  }
  .visualizer-btn svg { width: 22px; height: 22px; }

  /* Modal Styles */
  .visualizer-modal {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: #000; 
    z-index: 999999;
    display: flex;
    flex-direction: column;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    animation: vizFadeIn 0.3s ease-out forwards;
  }
  .visualizer-modal.hidden { display: none !important; }
  @keyframes vizFadeIn { from { opacity: 0; transform: scale(0.98); } to { opacity: 1; transform: scale(1); } }

  /* Header */
  .visualizer-header {
    background: rgba(20,20,20,0.95);
    backdrop-filter: blur(10px);
    padding: 18px 25px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: white;
  }
  .visualizer-header h2 { margin: 0; font-size: 1.1rem; font-weight: 500; letter-spacing: 0.5px; }
  .close-btn {
    background: rgba(255,255,255,0.1);
    border: none;
    width: 36px; height: 36px;
    border-radius: 50%;
    font-size: 20px;
    cursor: pointer;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .close-btn:hover { background: rgba(255,255,255,0.2); }

  /* Body & Controls */
  .visualizer-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }
  .visualizer-controls {
    position: absolute;
    top: 20px;
    left: 0; right: 0;
    z-index: 10;
    text-align: center;
    pointer-events: none; 
  }
  .upload-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: rgba(255,255,255,0.95);
    color: #000;
    border-radius: 30px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    pointer-events: auto;
    transition: transform 0.2s;
  }
  .upload-label:active { transform: scale(0.95); }
  .instructions { margin: 15px auto 0; font-size: 13px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.7); padding: 6px 16px; border-radius: 20px; display: inline-block; text-shadow: 0 1px 2px rgba(0,0,0,0.5); backdrop-filter: blur(5px); }

  /* Canvas Area */
  .visualizer-canvas {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: #111;
    display: flex;
    justify-content: center;
    align-items: center;
    touch-action: none !important; 
  }
  .empty-state {
    text-align: center;
    color: rgba(255,255,255,0.5);
    max-width: 300px;
    padding: 0 20px;
  }
  .empty-icon { font-size: 40px; margin-bottom: 15px; opacity: 0.5; }
  .empty-state p { line-height: 1.5; font-size: 15px; margin: 0; }
  
  .room-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .room-bg:not(.hidden) { opacity: 1; display: block; }

  /* --- 3D PERSPECTIVE MAGIC --- */
  .perspective-wrapper {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    perspective: 1200px; /* Deep perspective for realistic 3D */
    pointer-events: none; /* Let drag events pass to draggable-art */
  }

  /* Draggable Art Object */
  .draggable-art {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 250px; 
    cursor: grab;
    pointer-events: auto; /* Re-enable pointer events */
    /* Hardware acceleration for buttery smooth 3D */
    transform-style: preserve-3d;
    backface-visibility: hidden;
    transform: translate3d(-50%, -50%, 0) rotateY(0deg) scale(1);
  }
  
  .draggable-art.dragging {
    cursor: grabbing;
    z-index: 100;
  }

  /* 3D Frame Design */
  .art-frame {
    position: relative;
    width: 100%;
    background: #1a1a1a; /* Dark sleek premium frame */
    padding: 4px; /* Frame thickness */
    border-radius: 2px;
    box-shadow: 
      inset 0 0 0 1px rgba(255,255,255,0.15), /* Inner highlight */
      0 0 0 1px #000, /* Outer tight border */
      inset 0 0 15px rgba(0,0,0,0.8); /* Inner depth */
    transform: translateZ(20px); /* Push out from wall in 3D space */
  }
  
  .art-frame img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none; 
    box-shadow: inset 0 0 10px rgba(0,0,0,0.5); /* Canvas inner shadow */
  }

  /* Glass Reflection */
  .glass-reflection {
    position: absolute;
    top: 4px; left: 4px; right: 4px; bottom: 4px;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 100%);
    pointer-events: none;
  }

  /* Super Realistic 3D Wall Drop Shadow */
  .art-shadow {
    position: absolute;
    top: 5%; left: 5%;
    width: 90%; height: 90%;
    background: rgba(0,0,0,0.7);
    filter: blur(25px);
    transform: translateZ(0px); /* Sits on the back wall */
    z-index: -1;
    pointer-events: none;
    transition: filter 0.2s, background 0.2s;
  }
  .draggable-art.dragging .art-shadow {
    filter: blur(40px);
    background: rgba(0,0,0,0.4); /* Shadow softens when picked up */
    top: 10%; left: 10%; width: 80%; height: 80%;
  }

  /* --- 3D Tuning Sliders --- */
  .tuning-panel {
    background: rgba(15, 15, 15, 0.95);
    backdrop-filter: blur(15px);
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    z-index: 20;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.5);
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tuning-panel.hidden { display: none !important; }
  @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

  .slider-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .slider-group label {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .slider-group span { color: white; }
  
  /* Premium Custom Range Slider */
  .slider-group input[type=range] {
    -webkit-appearance: none;
    width: 100%;
    background: transparent;
  }
  .slider-group input[type=range]:focus { outline: none; }
  .slider-group input[type=range]::-webkit-slider-runnable-track {
    width: 100%;
    height: 6px;
    cursor: pointer;
    background: rgba(255,255,255,0.15);
    border-radius: 10px;
  }
  .slider-group input[type=range]::-webkit-slider-thumb {
    height: 20px;
    width: 20px;
    border-radius: 50%;
    background: #ffffff;
    cursor: pointer;
    -webkit-appearance: none;
    margin-top: -7px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.5);
  }

  /* Footer Actions */
  .visualizer-footer {
    background: #000;
    padding: 15px 20px;
    display: flex;
    justify-content: center;
    gap: 15px;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-bottom: env(safe-area-inset-bottom, 20px); 
  }
  .visualizer-footer button {
    padding: 14px 24px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    flex: 1;
    max-width: 250px;
    transition: all 0.2s;
  }
  .viz-btn-outline { background: #1a1a1a; color: white; border: 1px solid rgba(255,255,255,0.1); }
  .viz-btn-outline:active { background: rgba(255,255,255,0.1); }
  .viz-btn-primary { background: white; color: black; border: none; }
  .viz-btn-primary:active { transform: scale(0.96); }

</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const blockId = "{{ block.id }}";
    
    // Core Elements
    const triggerBtn = document.getElementById(`visualizer-trigger-${blockId}`);
    const modal = document.getElementById(`visualizer-modal-${blockId}`);
    const closeBtn = document.getElementById(`visualizer-close-${blockId}`);
    const uploadInput = document.getElementById(`visualizer-upload-${blockId}`);
    
    // Canvas & 3D Elements
    const bgImg = document.getElementById(`room-bg-${blockId}`);
    const artWrapper = document.getElementById(`draggable-art-${blockId}`);
    const canvasArea = document.getElementById(`visualizer-canvas-${blockId}`);
    const tuningPanel = document.getElementById(`tuning-panel-${blockId}`);
    
    // Sliders
    const sizeSlider = document.getElementById(`size-slider-${blockId}`);
    const tiltSlider = document.getElementById(`tilt-slider-${blockId}`);
    const sizeVal = document.getElementById(`size-val-${blockId}`);
    const tiltVal = document.getElementById(`tilt-val-${blockId}`);
    
    // UI States
    const emptyState = document.getElementById(`empty-state-${blockId}`);
    const instructions = document.getElementById(`viz-inst-${blockId}`);
    const topControls = document.getElementById(`visualizer-controls-${blockId}`);
    const footer = document.getElementById(`viz-footer-${blockId}`);
    const reuploadBtn = document.getElementById(`viz-reupload-${blockId}`);
    const doneBtn = document.getElementById(`viz-done-${blockId}`);

    if (!triggerBtn) return;

    // --- Modal Management ---
    triggerBtn.addEventListener('click', () => {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; 
        document.body.style.position = 'fixed';
        document.body.style.width = '100%';
    });

    const closeModal = () => {
        modal.classList.add('hidden');
        document.body.style.position = '';
        document.body.style.overflow = '';
        document.body.style.width = '';
    };

    closeBtn.addEventListener('click', closeModal);
    doneBtn.addEventListener('click', closeModal);
    reuploadBtn.addEventListener('click', () => uploadInput.click());

    // --- 3D State Variables ---
    let currentX = 0; // X Coordinate relative to center
    let currentY = 0; // Y Coordinate relative to center
    let currentScale = 1; // Base is 1 (250px)
    let currentRotY = 0; // 3D Tilt

    // Single source of truth for rendering position and 3D
    const render3D = () => {
        // using translate3d for hardware acceleration
        artWrapper.style.transform = `translate3d(calc(-50% + ${currentX}px), calc(-50% + ${currentY}px), 0) rotateY(${currentRotY}deg) scale(${currentScale})`;
        
        // Dynamic Lighting on Glass based on Rotation
        const reflection = artWrapper.querySelector('.glass-reflection');
        if(reflection) {
            // Tweak gradient angle based on tilt for realism
            const lightAngle = 135 + (currentRotY * 1.5);
            reflection.style.background = `linear-gradient(${lightAngle}deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 100%)`;
        }
    };

    // --- Image Upload ---
    uploadInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (ev) => {
                bgImg.src = ev.target.result;
                bgImg.classList.remove('hidden');
                artWrapper.classList.remove('hidden');
                emptyState.style.display = 'none';
                
                // Show tuning panel and hide initial giant upload button
                topControls.querySelector('.upload-label').style.display = 'none';
                instructions.classList.remove('hidden');
                tuningPanel.classList.remove('hidden');
                footer.classList.remove('hidden');
                
                // Reset Transforms
                currentX = 0;
                currentY = 0;
                currentScale = 1;
                currentRotY = 0;
                sizeSlider.value = 100;
                tiltSlider.value = 0;
                sizeVal.innerText = '100%';
                tiltVal.innerText = '0°';
                render3D();
            };
            reader.readAsDataURL(file);
        }
    });

    // --- Slider Listeners ---
    sizeSlider.addEventListener('input', (e) => {
        currentScale = e.target.value / 100;
        sizeVal.innerText = `${e.target.value}%`;
        render3D();
    });

    tiltSlider.addEventListener('input', (e) => {
        currentRotY = e.target.value;
        tiltVal.innerText = `${e.target.value}°`;
        render3D();
    });

    // --- PRECISE DRAGGING LOGIC ---
    let isDragging = false;
    let startPointX, startPointY;
    let initialPosX, initialPosY;

    canvasArea.addEventListener('touchmove', (e) => {
        // Only prevent default if we are interacting with the art, or if it's general scroll bounce
        if (isDragging || e.target === canvasArea) {
             e.preventDefault();
        }
    }, { passive: false });

    const handleDragStart = (e) => {
        // Prevent multi-touch drag starting
        if (e.touches && e.touches.length > 1) return;
        
        isDragging = true;
        artWrapper.classList.add('dragging');
        
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        
        startPointX = clientX;
        startPointY = clientY;
        
        initialPosX = currentX;
        initialPosY = currentY;
        
        e.preventDefault(); 
    };

    const handleDragMove = (e) => {
        if (!isDragging) return;
        
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        
        const deltaX = clientX - startPointX;
        const deltaY = clientY - startPointY;
        
        currentX = initialPosX + deltaX;
        currentY = initialPosY + deltaY;
        
        render3D();
    };

    const handleDragEnd = () => {
        isDragging = false;
        artWrapper.classList.remove('dragging');
    };

    // Bind Drag
    artWrapper.addEventListener('mousedown', handleDragStart);
    document.addEventListener('mousemove', handleDragMove);
    document.addEventListener('mouseup', handleDragEnd);
    
    artWrapper.addEventListener('touchstart', handleDragStart, { passive: false });
    document.addEventListener('touchmove', handleDragMove, { passive: false });
    document.addEventListener('touchend', handleDragEnd);

});
</script>

{% schema %}
{
  "name": "Room Visualizer (3D)",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}
