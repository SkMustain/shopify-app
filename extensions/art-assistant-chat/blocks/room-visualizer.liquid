<div class="art-visualizer-container">
  {% if product.featured_image %}
    <button id="visualizer-trigger-{{ block.id }}" class="visualizer-btn" type="button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
      <span>View in Your Room (Pro 3D)</span>
    </button>

    <!-- Modal Overlay -->
    <div id="visualizer-modal-{{ block.id }}" class="visualizer-modal hidden">
      <div class="visualizer-header">
        <h2>Pro 3D Room Visualizer</h2>
        <button id="visualizer-close-{{ block.id }}" class="close-btn">&times;</button>
      </div>
      
      <div class="visualizer-body">
        <!-- LEFT: The Interactive Canvas Area (70% on desktop) -->
        <div class="visualizer-canvas" id="visualizer-canvas-{{ block.id }}">
           <!-- Background Room Image -->
           <img id="room-bg-{{ block.id }}" class="room-bg hidden" src="" />
           
           <!-- Perspective Wrapper for 3D Math -->
           <div class="perspective-wrapper" id="perspective-wrapper-{{ block.id }}">
               <!-- The Product Image (Draggable & Rotatable) -->
               <div id="draggable-art-{{ block.id }}" class="draggable-art hidden">
                 <div class="art-frame">
                   <img src="{{ product.featured_image | image_url: width: 1024 }}" alt="{{ product.title }}">
                   <div class="glass-reflection"></div>
                 </div>
                 <div class="art-shadow"></div>
               </div>
           </div>
           
           <div class="empty-state" id="empty-state-{{ block.id }}">
             <div class="empty-icon">📸</div>
             <p>Take or upload a photo of your room to visualize this painting.</p>
             <label for="visualizer-upload-{{ block.id }}" class="upload-label" style="margin-top: 20px; padding: 12px 24px; font-size: 16px;">
               <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
               Upload Room Photo
             </label>
           </div>

           <!-- Mobile-only bottom overlay for action buttons -->
           <div class="visualizer-controls mobile-only-controls" id="visualizer-controls-{{ block.id }}">
              <div class="action-buttons-group" id="action-buttons-{{ block.id }}">
                <label for="visualizer-camera-{{ block.id }}" class="upload-label camera-label">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                  Take Photo
                </label>
                <input type="file" id="visualizer-camera-{{ block.id }}" accept="image/*" capture="environment" hidden>

                <label for="visualizer-upload-{{ block.id }}" class="upload-label">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                  Upload
                </label>
                <input type="file" id="visualizer-upload-{{ block.id }}" accept="image/*" hidden>
              </div>
              <p class="instructions hidden" id="viz-inst-{{ block.id }}">Drag art to move. Use sliders to adjust.</p>
           </div>
        </div>

        <!-- RIGHT: Controls Sidebar (30% on desktop, bottom on mobile) -->
        <div class="visualizer-sidebar" id="visualizer-sidebar-{{ block.id }}">
          <div class="sidebar-upload-section" id="sidebar-upload-{{ block.id }}">
            <h3>Upload Room</h3>
            <label for="visualizer-camera-{{ block.id }}" class="sidebar-upload-btn camera-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
              Take Photo
            </label>
            <label for="visualizer-upload-{{ block.id }}" class="sidebar-upload-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
              Upload Photo
            </label>
          </div>

          <!-- PRO 3D Tuning Panel -->
          <div class="tuning-panel hidden" id="tuning-panel-{{ block.id }}">
              <div class="tuning-header">
                  <h3>3D Adjustments</h3>
                  <button type="button" id="reset-3d-{{ block.id }}" class="reset-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                    Reset
                  </button>
              </div>
              <div class="sliders-container">
                  <div class="slider-group">
                      <label>Scale <span id="size-val-{{ block.id }}">100%</span></label>
                      <input type="range" id="size-slider-{{ block.id }}" min="20" max="250" value="100">
                  </div>
                  <div class="slider-group">
                      <label>Wall Pan (L/R) <span id="pany-val-{{ block.id }}">0°</span></label>
                      <input type="range" id="pany-slider-{{ block.id }}" min="-60" max="60" value="0">
                  </div>
                  <div class="slider-group">
                      <label>Wall Tilt (U/D) <span id="tiltx-val-{{ block.id }}">0°</span></label>
                      <input type="range" id="tiltx-slider-{{ block.id }}" min="-60" max="60" value="0">
                  </div>
              </div>
          </div>

          <div class="sidebar-footer hidden" id="viz-footer-{{ block.id }}">
            <button class="viz-btn-outline" id="viz-reupload-{{ block.id }}">Change Photo</button>
            <button class="viz-btn-primary" id="viz-done-{{ block.id }}">Looks Great!</button>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<style>
  /* Base Reset */
  .art-visualizer-container {
    position: relative;
    z-index: 999; /* Keep above header */
  }
  .art-visualizer-container * { box-sizing: border-box; }

  /* Button Styles */
  .visualizer-btn {
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, #0a0a0a, #2a2a2a);
    color: #ffd700; /* Gold accent for Pro */
    border: 1px solid rgba(255, 215, 0, 0.3);
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    margin: 20px 0;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 25px rgba(255, 215, 0, 0.1);
  }
  .visualizer-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(255, 215, 0, 0.2);
    border-color: rgba(255, 215, 0, 0.6);
  }
  .visualizer-btn svg { width: 22px; height: 22px; }

  /* Modal Styles */
  .visualizer-modal {
    position: fixed;
    top: 85px; left: 0; right: 0; bottom: 0;
    background: #050505; 
    z-index: 999999;
    border-top-left-radius: 24px;
    border-top-right-radius: 24px;
    box-shadow: 0 -10px 40px rgba(0,0,0,0.8);
    display: flex;
    flex-direction: column;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    animation: vizFadeIn 0.3s ease-out forwards;
    overflow: hidden;
  }
  .visualizer-modal.hidden { display: none !important; }
  @keyframes vizFadeIn { from { opacity: 0; transform: translateY(20px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }

  /* Header */
  .visualizer-header {
    background: rgba(10,10,10,0.95);
    backdrop-filter: blur(10px);
    padding: 15px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    color: white;
  }
  .visualizer-header h2 { margin: 0; font-size: 1.05rem; font-weight: 600; letter-spacing: 0.5px; color: #ffd700; }
  .close-btn {
    background: rgba(255,255,255,0.1);
    border: none;
    width: 32px; height: 32px;
    border-radius: 50%;
    font-size: 20px;
    cursor: pointer;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .close-btn:hover { background: rgba(255,255,255,0.2); }

  /* Body - 70/30 Split on Desktop, stacked on Mobile */
  .visualizer-body {
    flex: 1;
    display: flex;
    flex-direction: row;
    overflow: hidden;
    position: relative;
  }

  /* Canvas takes 70% on desktop, full width on mobile */
  .visualizer-canvas {
    flex: 7;
    position: relative;
    overflow: hidden;
    background: radial-gradient(circle at center, #1a1a1a 0%, #000 100%);
    display: flex;
    justify-content: center;
    align-items: center;
    touch-action: none !important;
    min-height: 300px;
  }

  /* Right sidebar takes 30% on desktop */
  .visualizer-sidebar {
    flex: 3;
    background: rgba(10, 10, 10, 0.98);
    border-left: 1px solid rgba(255, 215, 0, 0.15);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 20px 16px;
    overflow-y: auto;
    min-width: 260px;
    max-width: 340px;
  }

  /* Sidebar Upload Section */
  .sidebar-upload-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
  }
  .sidebar-upload-section h3 {
    color: #ffd700;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 5px 0;
  }
  .sidebar-upload-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    transition: transform 0.2s;
    background: linear-gradient(135deg, #fff, #f0f0f0);
    color: #000;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }
  .sidebar-upload-btn.camera-label {
    background: linear-gradient(135deg, #ffd700, #ffaa00);
    box-shadow: 0 4px 15px rgba(255,215,0,0.3);
  }
  .sidebar-upload-btn:active { transform: scale(0.95); }
  .sidebar-upload-btn svg { width: 16px; height: 16px; }

  /* Sidebar Footer */
  .sidebar-footer {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 15px;
  }
  .sidebar-footer.hidden { display: none !important; }
  .sidebar-footer button {
    padding: 10px 16px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    width: 100%;
    transition: all 0.2s;
  }

  /* Mobile overlay controls - hidden on desktop */
  .mobile-only-controls {
    position: absolute;
    bottom: 20px;
    top: auto;
    left: 0; right: 0;
    z-index: 10;
    text-align: center;
    pointer-events: none;
  }
  .action-buttons-group {
    display: flex;
    justify-content: center;
    gap: 10px;
    pointer-events: none;
  }
  .upload-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: linear-gradient(135deg, #fff, #f0f0f0);
    color: #000;
    border-radius: 30px;
    font-weight: 700;
    font-size: 12px;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(0,0,0,0.5);
    pointer-events: auto;
    transition: transform 0.2s;
  }
  .camera-label {
    background: linear-gradient(135deg, #ffd700, #ffaa00);
    box-shadow: 0 6px 20px rgba(255,215,0,0.3);
  }
  .upload-label svg { width: 14px; height: 14px; }
  .upload-label:active { transform: scale(0.95); }
  .instructions { margin: 8px auto 0; font-size: 11px; color: rgba(255,255,255,0.9); background: rgba(0,0,0,0.8); padding: 5px 12px; border-radius: 20px; display: inline-block; text-shadow: 0 1px 2px rgba(0,0,0,0.8); backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.1); }

  /* DESKTOP: show sidebar, hide mobile overlay */
  @media(min-width:768px) {
    .mobile-only-controls { display: none !important; }
    .visualizer-sidebar { display: flex; }
  }
  /* MOBILE: show sidebar as compact bottom strip */
  @media(max-width:767px) {
    .visualizer-body { flex-direction: column; }
    .mobile-only-controls { display: none !important; }
    .empty-state .upload-label { display: none !important; }
    .visualizer-canvas { flex: 1; min-height: 0; }
    .visualizer-sidebar {
      display: flex !important;
      flex-direction: column;
      flex: none;
      max-width: 100%;
      min-width: 100%;
      max-height: 160px;
      padding: 8px 12px;
      border-left: none;
      border-top: 1px solid rgba(255, 215, 0, 0.15);
      overflow-y: auto;
      gap: 6px;
    }
    .sidebar-upload-section { 
      flex-direction: row; 
      gap: 8px; 
      margin-bottom: 4px;
      align-items: center;
    }
    .sidebar-upload-section h3 { 
      display: none; 
    }
    .sidebar-upload-btn { 
      padding: 6px 12px; 
      font-size: 11px; 
      gap: 4px; 
    }
    .sidebar-upload-btn svg { width: 12px; height: 12px; }
    .tuning-panel { 
      padding: 6px 0 0 0; 
      gap: 6px; 
    }
    .tuning-header h3 { font-size: 11px; }
    .reset-btn { padding: 3px 8px; font-size: 10px; }
    .sliders-container { gap: 6px; }
    .slider-group { gap: 2px; }
    .slider-group label { font-size: 10px; }
    .sidebar-footer { 
      flex-direction: row; 
      gap: 8px; 
      margin-top: 6px;
    }
    .sidebar-footer button { 
      padding: 7px 12px; 
      font-size: 11px; 
    }
  }

  .empty-state {
    text-align: center;
    color: rgba(255,255,255,0.5);
    max-width: 300px;
    padding: 0 20px;
  }
  .empty-icon { font-size: 40px; margin-bottom: 15px; opacity: 0.5; }
  .empty-state p { line-height: 1.5; font-size: 15px; margin: 0; }
  
  .room-bg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .room-bg:not(.hidden) { opacity: 1; display: block; }

  /* --- PRO 3D PERSPECTIVE MAGIC --- */
  .perspective-wrapper {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    perspective: 1000px;
    pointer-events: none; 
  }

  /* Draggable Art Object */
  .draggable-art {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 350px; 
    cursor: grab;
    pointer-events: auto; 
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }
  @media(min-width:768px){ .draggable-art { width: 500px; } }
  
  .draggable-art.dragging {
    cursor: grabbing;
    z-index: 100;
  }

  /* 3D Frame Design */
  .art-frame {
    position: relative;
    width: 100%;
    background: #111;
    padding: 6px;
    border-radius: 3px;
    box-shadow: 
      inset 0 0 0 1px rgba(255,255,255,0.2), 
      0 0 0 1px #000, 
      0 0 0 2px rgba(255,215,0,0.1),
      inset 0 0 20px rgba(0,0,0,0.9); 
    transform: translateZ(25px);
  }
  
  .art-frame img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none; 
    box-shadow: inset 0 0 15px rgba(0,0,0,0.8); 
  }

  /* Glass Reflection */
  .glass-reflection {
    position: absolute;
    top: 6px; left: 6px; right: 6px; bottom: 6px;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 100%);
    pointer-events: none;
  }

  /* Super Realistic 3D Wall Drop Shadow */
  .art-shadow {
    position: absolute;
    top: 10%; left: 10%;
    width: 80%; height: 80%;
    background: rgba(0,0,0,0.8);
    filter: blur(30px);
    transform: translateZ(-5px);
    z-index: -1;
    pointer-events: none;
    transition: filter 0.2s, background 0.2s, transform 0.2s;
  }
  .draggable-art.dragging .art-shadow {
    filter: blur(45px);
    background: rgba(0,0,0,0.5); 
    transform: translateZ(-20px);
  }

  /* --- PRO 3D Tuning Sliders (inside sidebar) --- */
  .tuning-panel {
    background: transparent;
    border-top: 1px solid rgba(255, 215, 0, 0.15);
    padding: 15px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tuning-panel.hidden { display: none !important; }

  .tuning-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 5px;
  }
  .tuning-header h3 { margin: 0; color: #ffd700; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
  
  .reset-btn {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      color: white;
      padding: 5px 12px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 5px;
      text-transform: uppercase;
  }
  .reset-btn:active { background: rgba(255,255,255,0.2); }

  .sliders-container {
      display: grid;
      gap: 12px;
  }

  .slider-group { display: flex; flex-direction: column; gap: 4px; }
  .slider-group label {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    font-weight: 500;
  }
  .slider-group span { color: #fff; font-variant-numeric: tabular-nums; }
  
  /* Premium Custom Range Slider */
  .slider-group input[type=range] {
    -webkit-appearance: none;
    width: 100%;
    background: transparent;
  }
  .slider-group input[type=range]:focus { outline: none; }
  .slider-group input[type=range]::-webkit-slider-runnable-track {
    width: 100%;
    height: 4px;
    cursor: pointer;
    background: rgba(255,255,255,0.1);
    border-radius: 10px;
  }
  .slider-group input[type=range]::-webkit-slider-thumb {
    height: 14px;
    width: 14px;
    border-radius: 50%;
    background: #ffd700;
    cursor: pointer;
    -webkit-appearance: none;
    margin-top: -5px;
    box-shadow: 0 0 10px rgba(255, 215, 0, 0.4);
    border: 2px solid #000;
  }

  /* Footer Buttons */
  .viz-btn-outline { background: #1a1a1a; color: white; border: 1px solid rgba(255,255,255,0.1); }
  .viz-btn-outline:active { background: rgba(255,255,255,0.1); }
  .viz-btn-primary { background: linear-gradient(135deg, #ffd700, #ffaa00); color: black; border: none; box-shadow: 0 4px 15px rgba(255,215,0,0.3); }
  .viz-btn-primary:active { transform: scale(0.96); }

</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const blockId = "{{ block.id }}";
    
    // Core Elements
    const triggerBtn = document.getElementById(`visualizer-trigger-${blockId}`);
    const modal = document.getElementById(`visualizer-modal-${blockId}`);
    const closeBtn = document.getElementById(`visualizer-close-${blockId}`);
    const uploadInput = document.getElementById(`visualizer-upload-${blockId}`);
    const cameraInput = document.getElementById(`visualizer-camera-${blockId}`);
    
    // Canvas & 3D Elements
    const bgImg = document.getElementById(`room-bg-${blockId}`);
    const artWrapper = document.getElementById(`draggable-art-${blockId}`);
    const canvasArea = document.getElementById(`visualizer-canvas-${blockId}`);
    const tuningPanel = document.getElementById(`tuning-panel-${blockId}`);
    
    // Controls
    const sizeSlider = document.getElementById(`size-slider-${blockId}`);
    const panySlider = document.getElementById(`pany-slider-${blockId}`);
    const tiltxSlider = document.getElementById(`tiltx-slider-${blockId}`);
    
    const sizeVal = document.getElementById(`size-val-${blockId}`);
    const panyVal = document.getElementById(`pany-val-${blockId}`);
    const tiltxVal = document.getElementById(`tiltx-val-${blockId}`);
    
    const resetBtn = document.getElementById(`reset-3d-${blockId}`);
    
    // UI States
    const emptyState = document.getElementById(`empty-state-${blockId}`);
    const instructions = document.getElementById(`viz-inst-${blockId}`);
    const topControls = document.getElementById(`visualizer-controls-${blockId}`);
    const footer = document.getElementById(`viz-footer-${blockId}`);
    const reuploadBtn = document.getElementById(`viz-reupload-${blockId}`);
    const doneBtn = document.getElementById(`viz-done-${blockId}`);
    const actionButtonsGroup = document.getElementById(`action-buttons-${blockId}`);
    const sidebarUpload = document.getElementById(`sidebar-upload-${blockId}`);

    if (!triggerBtn) return;

    // --- Modal Management ---
    triggerBtn.addEventListener('click', () => {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; 
        document.body.style.position = 'fixed';
        document.body.style.width = '100%';
    });

    const closeModal = () => {
        modal.classList.add('hidden');
        document.body.style.position = '';
        document.body.style.overflow = '';
        document.body.style.width = '';
    };

    closeBtn.addEventListener('click', closeModal);
    doneBtn.addEventListener('click', closeModal);
    reuploadBtn.addEventListener('click', () => uploadInput.click());

    // --- PRO 3D Variables ---
    let currentX = 0; 
    let currentY = 0; 
    let currentScale = 1; 
    let currentRotY = 0; // Pan (Left/Right)
    let currentRotX = 0; // Tilt (Up/Down)

    // Engine: Single source of truth for rendering
    const render3D = () => {
        // Order matters: position -> rotate -> scale
        artWrapper.style.transform = `translate3d(calc(-50% + ${currentX}px), calc(-50% + ${currentY}px), 0) rotateX(${currentRotX}deg) rotateY(${currentRotY}deg) scale(${currentScale})`;
        
        // Dynamic Lighting based on combined rotation
        const reflection = artWrapper.querySelector('.glass-reflection');
        if(reflection) {
            const lightAngle = 135 + (currentRotY * 1.5) - (currentRotX * 1.5);
            reflection.style.background = `linear-gradient(${lightAngle}deg, rgba(255,255,255,0.25) 0%, rgba(255,255,255,0) 50%, rgba(255,255,255,0) 100%)`;
        }
        
        // Dynamic Drop Shadow offset based on tilt
        const shadow = artWrapper.querySelector('.art-shadow');
        if(shadow && !isDragging) {
             const shiftX = (currentRotY / 60) * -15;
             const shiftY = (currentRotX / 60) * 15;
             shadow.style.top = `calc(10% + ${shiftY}px)`;
             shadow.style.left = `calc(10% + ${shiftX}px)`;
        }
    };

    const reset3DControls = () => {
        currentScale = 1;
        currentRotY = 0;
        currentRotX = 0;
        
        sizeSlider.value = 100;
        panySlider.value = 0;
        tiltxSlider.value = 0;
        
        sizeVal.innerText = '100%';
        panyVal.innerText = '0°';
        tiltxVal.innerText = '0°';
        
        render3D();
    };

    resetBtn.addEventListener('click', reset3DControls);

    // --- Image Upload ---
    const handleImageFile = (e) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (ev) => {
                bgImg.src = ev.target.result;
                bgImg.classList.remove('hidden');
                artWrapper.classList.remove('hidden');
                emptyState.style.display = 'none';
                
                // Show Pro tuning panel, hide upload buttons
                if (actionButtonsGroup) actionButtonsGroup.style.display = 'none';
                if (sidebarUpload) sidebarUpload.style.display = 'none';
                instructions.classList.remove('hidden');
                tuningPanel.classList.remove('hidden');
                footer.classList.remove('hidden');
                
                // Reset Transforms & Position for new image
                currentX = 0;
                currentY = 0;
                reset3DControls();
            };
            reader.readAsDataURL(file);
        }
    };
    
    uploadInput.addEventListener('change', handleImageFile);
    if (cameraInput) cameraInput.addEventListener('change', handleImageFile);

    // --- Slider Listeners ---
    sizeSlider.addEventListener('input', (e) => {
        currentScale = e.target.value / 100;
        sizeVal.innerText = `${e.target.value}%`;
        render3D();
    });

    panySlider.addEventListener('input', (e) => {
        currentRotY = e.target.value;
        panyVal.innerText = `${e.target.value}°`;
        render3D();
    });

    tiltxSlider.addEventListener('input', (e) => {
        currentRotX = e.target.value;
        tiltxVal.innerText = `${e.target.value}°`;
        render3D();
    });

    // --- PRECISE DRAGGING LOGIC ---
    let isDragging = false;
    let startPointX, startPointY;
    let initialPosX, initialPosY;

    canvasArea.addEventListener('touchmove', (e) => {
        if (isDragging || e.target === canvasArea) {
             e.preventDefault();
        }
    }, { passive: false });

    const handleDragStart = (e) => {
        // Prevent multi-touch
        if (e.touches && e.touches.length > 1) return;
        
        isDragging = true;
        artWrapper.classList.add('dragging');
        
        // Slightly re-center drop shadow for drag visual feedback
        const shadow = artWrapper.querySelector('.art-shadow');
        if(shadow) {
            shadow.style.top = '10%';
            shadow.style.left = '10%';
        }
        
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        
        startPointX = clientX;
        startPointY = clientY;
        
        initialPosX = currentX;
        initialPosY = currentY;
        
        e.preventDefault(); 
    };

    const handleDragMove = (e) => {
        if (!isDragging) return;
        
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        
        const deltaX = clientX - startPointX;
        const deltaY = clientY - startPointY;
        
        currentX = initialPosX + deltaX;
        currentY = initialPosY + deltaY;
        
        render3D();
    };

    const handleDragEnd = () => {
        isDragging = false;
        artWrapper.classList.remove('dragging');
        
        // Re-apply rotation-based shadow shift
        render3D(); 
    };

    // Bind Drag
    artWrapper.addEventListener('mousedown', handleDragStart);
    document.addEventListener('mousemove', handleDragMove);
    document.addEventListener('mouseup', handleDragEnd);
    
    artWrapper.addEventListener('touchstart', handleDragStart, { passive: false });
    document.addEventListener('touchmove', handleDragMove, { passive: false });
    document.addEventListener('touchend', handleDragEnd);

});
</script>

